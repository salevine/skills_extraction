# Copy to .env.local (preferred) or .env in this repo root.

# Backend: "ollama" (default) or "openrouter"
# SKILLS_BACKEND=openrouter

# Ollama (default backend)
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter (required when SKILLS_BACKEND=openrouter)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional model overrides
# SKILLS_EXTRACTOR_MODEL=qwen2.5:14b
# SKILLS_VERIFIER_MODEL=mistral-nemo:12b
# When using OpenRouter, model names use provider/model format:
#   SKILLS_EXTRACTOR_MODEL=qwen/qwen3-14b
#   SKILLS_VERIFIER_MODEL=mistralai/mistral-nemo
